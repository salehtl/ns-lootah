---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { t } from '../../i18n/translations';

const lang = 'ar' as const;
const currentPath = '/ar/contact';
const strings = t(lang);

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: strings.nav.home, item: 'https://nslootah.com/ar/' },
    { '@type': 'ListItem', position: 2, name: strings.nav.contact, item: 'https://nslootah.com/ar/contact' },
  ],
};
---

<BaseLayout
  title={strings.contact.metaTitle}
  description={strings.contact.metaDescription}
  lang={lang}
  currentPath={currentPath}
  jsonLd={jsonLd}
>
  <section class="page-hero">
    <div class="container">
      <h1>{strings.contact.heading}</h1>
      <p class="subheading">{strings.contact.subheading}</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <p class="section-intro">{strings.contact.text}</p>

      <div class="contact-info">
        <div class="info-block">
          <h2>{strings.contact.addressLabel}</h2>
          <p>{strings.site.address}</p>
        </div>
        <div class="info-block">
          <h2>{strings.contact.phoneLabel}</h2>
          <p><a href={`https://wa.me/${strings.site.phone.replace(/[^0-9]/g, '')}`}>{strings.site.phone}</a></p>
        </div>
        <div class="info-block">
          <h2>{strings.contact.emailLabel}</h2>
          <p><a href={`mailto:${strings.site.email}`}>{strings.site.email}</a></p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-hero {
    padding: var(--space-24) var(--content-padding) var(--space-16);
    background-color: var(--color-near-black);
    color: var(--color-white);
  }

  .page-hero h1 {
    color: var(--color-white);
    font-size: var(--text-display);
    margin-bottom: var(--space-4);
  }

  .subheading {
    font-size: var(--text-h3);
    color: rgba(255, 255, 255, 0.8);
  }

  .container {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .section {
    padding: var(--space-24) var(--content-padding);
  }

  .section-intro {
    color: var(--color-charcoal);
    margin-bottom: var(--space-12);
    max-width: 55ch;
  }

  .contact-info {
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
  }

  .info-block h2 {
    font-size: var(--text-small);
    color: var(--color-mid-gray);
    margin-bottom: var(--space-2);
  }

  .info-block p {
    font-size: var(--text-h3);
    font-weight: 500;
  }

  .info-block a {
    color: var(--color-near-black);
    text-decoration: none;
  }

  .info-block a:hover {
    color: var(--color-gold);
  }
</style>
