---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { t } from '../../i18n/translations';

const lang = 'ar' as const;
const currentPath = '/ar/real-fresh';
const strings = t(lang);

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: strings.nav.home, item: 'https://nslootah.com/ar/' },
    { '@type': 'ListItem', position: 2, name: strings.nav.realFresh, item: 'https://nslootah.com/ar/real-fresh' },
  ],
};
---

<BaseLayout
  title={strings.realFresh.metaTitle}
  description={strings.realFresh.metaDescription}
  lang={lang}
  currentPath={currentPath}
  jsonLd={jsonLd}
>
  <section class="page-hero">
    <div class="container">
      <h1>{strings.realFresh.heading}</h1>
      <p class="intro">{strings.realFresh.intro}</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2>{strings.realFresh.overviewHeading}</h2>
      <p class="lead">{strings.realFresh.overviewText}</p>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container vision-strengths">
      <div class="vs-card">
        <h2>{strings.realFresh.visionHeading}</h2>
        <p>{strings.realFresh.visionText}</p>
      </div>
      <div class="vs-card">
        <h2>{strings.realFresh.strengthsHeading}</h2>
        <ul class="strengths-list">
          {strings.realFresh.strengths.map((item) => <li>{item}</li>)}
        </ul>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2>{strings.realFresh.productsHeading}</h2>
      <div class="two-col">
        <div class="card">
          <h3>{strings.realFresh.foodTitle}</h3>
          <ul>
            {strings.realFresh.foodProducts.map((item) => <li>{item}</li>)}
          </ul>
        </div>
        <div class="card">
          <h3>{strings.realFresh.nonFoodTitle}</h3>
          <ul>
            {strings.realFresh.nonFoodProducts.map((item) => <li>{item}</li>)}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container commitment">
      <h2>{strings.realFresh.qualityHeading}</h2>
      <p>{strings.realFresh.qualityText}</p>
    </div>
  </section>

  <section class="section">
    <div class="container contact-section">
      <h2>{strings.realFresh.contactHeading}</h2>
      <address class="contact-info">
        <p>{strings.realFresh.address}</p>
        <p><a href={`tel:${strings.realFresh.phone.replace(/\s/g, '')}`}>{strings.realFresh.phone}</a></p>
        <p><a href={`mailto:${strings.realFresh.email}`}>{strings.realFresh.email}</a></p>
      </address>
      <a href={strings.realFresh.websiteUrl} target="_blank" rel="noopener noreferrer" class="cta-button">{strings.realFresh.websiteCta}</a>
    </div>
  </section>
</BaseLayout>

<style>
  .page-hero {
    padding: var(--space-24) var(--content-padding) var(--space-16);
    background-color: var(--color-near-black);
    color: var(--color-white);
  }

  .page-hero h1 {
    color: var(--color-white);
    font-size: var(--text-display);
    margin-bottom: var(--space-6);
  }

  .intro {
    font-size: var(--text-h3);
    color: rgba(255, 255, 255, 0.8);
    max-width: 55ch;
  }

  .container {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .section {
    padding: var(--space-24) var(--content-padding);
  }

  .section-alt {
    background-color: var(--color-bg-alt);
  }

  .section h2 {
    margin-bottom: var(--space-8);
  }

  .lead {
    font-size: var(--text-h3);
    line-height: 1.6;
    color: var(--color-charcoal);
    max-width: 65ch;
  }

  .vision-strengths {
    display: grid;
    gap: var(--space-8);
  }

  .vs-card {
    background-color: var(--color-white);
    box-shadow: var(--shadow-card);
    border-radius: var(--radius-md);
    padding: var(--space-8);
    border-top: 3px solid var(--color-gold);
  }

  .vs-card p {
    color: var(--color-charcoal);
    line-height: 1.7;
  }

  .strengths-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .strengths-list li {
    position: relative;
    color: var(--color-charcoal);
    line-height: 1.6;
    padding-right: var(--space-6);
  }

  .strengths-list li::before {
    content: '';
    position: absolute;
    right: 0;
    top: 0.65em;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background-color: var(--color-gold);
  }

  html[dir="ltr"] .strengths-list li {
    padding-right: 0;
    padding-left: var(--space-6);
  }

  html[dir="ltr"] .strengths-list li::before {
    right: auto;
    left: 0;
  }

  .two-col {
    display: grid;
    gap: var(--space-8);
  }

  .card {
    background-color: var(--color-white);
    box-shadow: var(--shadow-card);
    border-radius: var(--radius-md);
    padding: var(--space-8);
  }

  .card h3 {
    margin-bottom: var(--space-4);
  }

  .card ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .card li {
    position: relative;
    padding-right: var(--space-4);
  }

  .card li::before {
    content: '';
    position: absolute;
    right: 0;
    top: 0.7em;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background-color: var(--color-gold);
  }

  html[dir="ltr"] .card li {
    padding-right: 0;
    padding-left: var(--space-4);
  }

  html[dir="ltr"] .card li::before {
    right: auto;
    left: 0;
  }

  .commitment {
    text-align: center;
  }

  .commitment p {
    max-width: 55ch;
    margin: 0 auto;
    font-size: var(--text-h3);
    color: var(--color-charcoal);
    line-height: 1.6;
  }

  .contact-section {
    text-align: center;
  }

  .contact-info {
    font-style: normal;
    margin-bottom: var(--space-8);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    color: var(--color-charcoal);
  }

  .contact-info a {
    color: var(--color-gold-dark);
    text-decoration: none;
    transition: color 0.3s ease;
  }

  .contact-info a:hover {
    color: var(--color-gold);
  }

  .cta-button {
    display: inline-block;
    padding: var(--space-3) var(--space-8);
    background-color: var(--color-gold);
    color: var(--color-near-black);
    font-weight: 600;
    text-decoration: none;
    border-radius: var(--radius-md);
    transition: background-color 0.3s ease;
  }

  .cta-button:hover {
    background-color: var(--color-gold-dark);
    color: var(--color-white);
  }

  @media (prefers-reduced-motion: reduce) {
    .contact-info a,
    .cta-button {
      transition: none;
    }
  }

  @media (min-width: 48rem) {
    .vision-strengths {
      grid-template-columns: 1fr 1fr;
    }

    .two-col {
      grid-template-columns: 1fr 1fr;
    }
  }
</style>
