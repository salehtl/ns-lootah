---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { t } from '../../i18n/translations';

const lang = 'ar' as const;
const currentPath = '/ar/souo-moto';
const strings = t(lang);

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: strings.nav.home, item: 'https://nslootah.com/ar/' },
    { '@type': 'ListItem', position: 2, name: strings.nav.souoMoto, item: 'https://nslootah.com/ar/souo-moto' },
  ],
};
---

<BaseLayout
  title={strings.souoMoto.metaTitle}
  description={strings.souoMoto.metaDescription}
  lang={lang}
  currentPath={currentPath}
  jsonLd={jsonLd}
>
  <section class="page-hero">
    <div class="container">
      <h1>{strings.souoMoto.heading}</h1>
      <p class="intro">{strings.souoMoto.intro}</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2>{strings.souoMoto.overviewHeading}</h2>
      <p class="lead">{strings.souoMoto.overviewText}</p>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container">
      <h2>{strings.souoMoto.modelsHeading}</h2>
      <div class="two-col">
        <div class="card">
          <h3>{strings.souoMoto.model1Name}</h3>
          <p>{strings.souoMoto.model1Desc}</p>
        </div>
        <div class="card">
          <h3>{strings.souoMoto.model2Name}</h3>
          <p>{strings.souoMoto.model2Desc}</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container cta-section">
      <a href={strings.souoMoto.websiteUrl} target="_blank" rel="noopener noreferrer" class="cta-button">
        <span class="cta-label">{strings.souoMoto.websiteCta}</span>
        <span class="cta-arrow" aria-hidden="true"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7"/><path d="M7 7h10v10"/></svg></span>
      </a>
    </div>
  </section>
</BaseLayout>

<style>
  .page-hero {
    padding: var(--space-24) var(--content-padding) var(--space-16);
    background-color: var(--color-near-black);
    color: var(--color-white);
  }

  .page-hero h1 {
    color: var(--color-white);
    font-size: var(--text-display);
    margin-bottom: var(--space-6);
  }

  .intro {
    font-size: var(--text-h3);
    color: rgba(255, 255, 255, 0.8);
    max-width: 55ch;
  }

  .container {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .section {
    padding: var(--space-24) var(--content-padding);
  }

  .section-alt {
    background-color: var(--color-bg-alt);
  }

  .section h2 {
    margin-bottom: var(--space-8);
  }

  .lead {
    font-size: var(--text-h3);
    line-height: 1.6;
    color: var(--color-charcoal);
    max-width: 65ch;
  }

  .two-col {
    display: grid;
    gap: var(--space-8);
  }

  .card {
    background-color: var(--color-white);
    box-shadow: var(--shadow-card);
    border-radius: var(--radius-md);
    padding: var(--space-8);
  }

  .card h3 {
    margin-bottom: var(--space-4);
  }

  .card p {
    color: var(--color-charcoal);
    line-height: 1.7;
  }

  .cta-section {
    text-align: center;
  }

  .cta-button {
    display: inline-flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-4) var(--space-8);
    background-color: transparent;
    color: var(--color-gold-dark);
    font-weight: 700;
    font-size: var(--text-button);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: none;
    border: 2px solid var(--color-gold);
    border-radius: 0;
    position: relative;
    overflow: hidden;
    transition: color 0.3s ease, border-color 0.3s ease;
  }

  .cta-button::before {
    content: '';
    position: absolute;
    inset: 0;
    background-color: var(--color-gold);
    transform: scaleX(0);
    transform-origin: right;
    transition: transform 0.3s ease;
    z-index: 0;
  }

  html[dir="ltr"] .cta-button::before {
    transform-origin: left;
  }

  .cta-button:hover::before {
    transform: scaleX(1);
  }

  .cta-button:hover {
    color: var(--color-near-black);
    border-color: var(--color-gold);
  }

  .cta-label,
  .cta-arrow {
    position: relative;
    z-index: 1;
  }

  .cta-arrow {
    display: inline-flex;
    transform: scaleX(-1);
    transition: transform 0.3s ease;
  }

  .cta-button:hover .cta-arrow {
    transform: scaleX(-1) translate(3px, -3px);
  }

  html[dir="ltr"] .cta-arrow {
    transform: scaleX(1);
  }

  html[dir="ltr"] .cta-button:hover .cta-arrow {
    transform: translate(3px, -3px);
  }

  .cta-button:focus-visible {
    outline: 2px solid var(--color-gold-dark);
    outline-offset: 3px;
  }

  @media (prefers-reduced-motion: reduce) {
    .cta-button,
    .cta-button::before,
    .cta-arrow {
      transition: none;
    }
  }

  @media (min-width: 48rem) {
    .two-col {
      grid-template-columns: 1fr 1fr;
    }
  }
</style>
