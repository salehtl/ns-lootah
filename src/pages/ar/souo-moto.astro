---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { t } from '../../i18n/translations';

const lang = 'ar' as const;
const currentPath = '/ar/souo-moto';
const strings = t(lang);

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: strings.nav.home, item: 'https://nslootah.com/ar/' },
    { '@type': 'ListItem', position: 2, name: strings.nav.souoMoto, item: 'https://nslootah.com/ar/souo-moto' },
  ],
};
---

<BaseLayout
  title={strings.souoMoto.metaTitle}
  description={strings.souoMoto.metaDescription}
  lang={lang}
  currentPath={currentPath}
  jsonLd={jsonLd}
>
  <section class="page-hero">
    <div class="container">
      <h1>{strings.souoMoto.heading}</h1>
      <p class="intro">{strings.souoMoto.intro}</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2>{strings.souoMoto.overviewHeading}</h2>
      <p class="lead">{strings.souoMoto.overviewText}</p>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container">
      <h2>{strings.souoMoto.modelsHeading}</h2>
      <div class="two-col">
        <div class="card">
          <h3>{strings.souoMoto.model1Name}</h3>
          <p>{strings.souoMoto.model1Desc}</p>
        </div>
        <div class="card">
          <h3>{strings.souoMoto.model2Name}</h3>
          <p>{strings.souoMoto.model2Desc}</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container cta-section">
      <a href={strings.souoMoto.websiteUrl} target="_blank" rel="noopener noreferrer" class="cta-button">{strings.souoMoto.websiteCta}</a>
    </div>
  </section>
</BaseLayout>

<style>
  .page-hero {
    padding: var(--space-24) var(--content-padding) var(--space-16);
    background-color: var(--color-near-black);
    color: var(--color-white);
  }

  .page-hero h1 {
    color: var(--color-white);
    font-size: var(--text-display);
    margin-bottom: var(--space-6);
  }

  .intro {
    font-size: var(--text-h3);
    color: rgba(255, 255, 255, 0.8);
    max-width: 55ch;
  }

  .container {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .section {
    padding: var(--space-24) var(--content-padding);
  }

  .section-alt {
    background-color: var(--color-bg-alt);
  }

  .section h2 {
    margin-bottom: var(--space-8);
  }

  .lead {
    font-size: var(--text-h3);
    line-height: 1.6;
    color: var(--color-charcoal);
    max-width: 65ch;
  }

  .two-col {
    display: grid;
    gap: var(--space-8);
  }

  .card {
    background-color: var(--color-white);
    box-shadow: var(--shadow-card);
    border-radius: var(--radius-md);
    padding: var(--space-8);
  }

  .card h3 {
    margin-bottom: var(--space-4);
  }

  .card p {
    color: var(--color-charcoal);
    line-height: 1.7;
  }

  .cta-section {
    text-align: center;
  }

  .cta-button {
    display: inline-block;
    padding: var(--space-3) var(--space-8);
    background-color: var(--color-gold);
    color: var(--color-near-black);
    font-weight: 600;
    text-decoration: none;
    border-radius: var(--radius-md);
    transition: background-color 0.3s ease;
  }

  .cta-button:hover {
    background-color: var(--color-gold-dark);
    color: var(--color-white);
  }

  @media (prefers-reduced-motion: reduce) {
    .cta-button {
      transition: none;
    }
  }

  @media (min-width: 48rem) {
    .two-col {
      grid-template-columns: 1fr 1fr;
    }
  }
</style>
