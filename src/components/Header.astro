---
import type { Lang } from '../i18n/types';
import { t } from '../i18n/translations';
import { getLocalizedPath } from '../i18n/utils';
import LanguageSwitcher from './LanguageSwitcher.astro';

interface Props {
  lang: Lang;
  currentPath: string;
}

const { lang, currentPath } = Astro.props;
const strings = t(lang);

const navLinks = [
  { label: strings.nav.about, href: getLocalizedPath('/about', lang) },
  { label: strings.nav.nslTrading, href: getLocalizedPath('/nsl-trading', lang) },
  { label: strings.nav.projectUpgraded, href: getLocalizedPath('/project-upgraded', lang) },
  { label: strings.nav.news, href: getLocalizedPath('/news', lang) },
  { label: strings.nav.careers, href: getLocalizedPath('/careers', lang) },
  { label: strings.nav.contact, href: getLocalizedPath('/contact', lang) },
];
---

<header class="header">
  <div class="header-inner">
    <a href={getLocalizedPath('/', lang)} class="logo" aria-label={strings.site.name}>
      <img src="/images/logo.webp" alt={strings.alt.logo} width="300" height="66" />
    </a>

    <nav aria-label={lang === 'en' ? 'Main navigation' : 'التنقل الرئيسي'}>
      <details class="mobile-menu">
        <summary aria-label={strings.nav.openMenu}>
          <svg class="icon-menu" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <line x1="3" y1="6" x2="21" y2="6" />
            <line x1="3" y1="12" x2="21" y2="12" />
            <line x1="3" y1="18" x2="21" y2="18" />
          </svg>
          <svg class="icon-close" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <line x1="6" y1="6" x2="18" y2="18" />
            <line x1="6" y1="18" x2="18" y2="6" />
          </svg>
        </summary>
        <ul class="nav-list">
          {navLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class:list={['nav-link', { active: currentPath.startsWith(link.href) }]}
              >
                {link.label}
              </a>
            </li>
          ))}
          <li class="lang-switch-mobile">
            <LanguageSwitcher lang={lang} currentPath={currentPath} />
          </li>
        </ul>
      </details>

      <ul class="nav-list-desktop">
        {navLinks.map((link) => (
          <li>
            <a
              href={link.href}
              class:list={['nav-link', { active: currentPath.startsWith(link.href) }]}
            >
              {link.label}
            </a>
          </li>
        ))}
        <li>
          <LanguageSwitcher lang={lang} currentPath={currentPath} />
        </li>
      </ul>
    </nav>
  </div>
</header>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 50;
    background-color: #000000;
    border-bottom: none;
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: var(--max-width);
    margin: 0 auto;
    padding: var(--space-4) var(--content-padding);
  }

  .logo {
    display: flex;
    align-items: center;
    text-decoration: none;
  }

  .logo img {
    height: 50px;
    width: auto;
  }

  /* Desktop nav */
  .nav-list-desktop {
    display: none;
    list-style: none;
    align-items: center;
    gap: var(--space-6);
  }

  .nav-link {
    font-size: var(--text-small);
    color: rgba(255, 255, 255, 0.8);
    text-decoration: none;
    transition: color 0.3s ease;
  }

  html[dir="rtl"] .nav-link {
    font-size: var(--text-body);
  }

  .nav-link:hover,
  .nav-link.active {
    color: var(--color-gold);
  }

  /* Mobile menu */
  .mobile-menu {
    display: block;
  }

  .mobile-menu summary {
    display: flex;
    align-items: center;
    cursor: pointer;
    list-style: none;
    color: rgba(255, 255, 255, 0.8);
  }

  .mobile-menu summary::-webkit-details-marker {
    display: none;
  }

  .mobile-menu summary::marker {
    display: none;
    content: '';
  }

  .icon-close {
    display: none;
  }

  .mobile-menu[open] .icon-menu {
    display: none;
  }

  .mobile-menu[open] .icon-close {
    display: block;
  }

  .mobile-menu .nav-list {
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    list-style: none;
    background-color: #000000;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    padding: var(--space-6) var(--content-padding);
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .lang-switch-mobile {
    padding-top: var(--space-4);
    border-top: 1px solid var(--color-border);
  }

  @media (min-width: 48rem) {
    .mobile-menu {
      display: none;
    }

    .nav-list-desktop {
      display: flex;
    }
  }
</style>
