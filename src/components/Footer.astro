---
import type { Lang } from '../i18n/types';
import { t } from '../i18n/translations';
import { getLocalizedPath } from '../i18n/utils';
import LanguageSwitcher from './LanguageSwitcher.astro';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const strings = t(lang);
const currentYear = new Date().getFullYear();

const navLinks = [
  { label: strings.nav.about, href: getLocalizedPath('/about', lang) },
  { label: strings.nav.contact, href: getLocalizedPath('/contact', lang) },
];
---

<footer class="footer">
  <div class="footer-inner">
    <div class="footer-top">
      <a href={getLocalizedPath('/', lang)} class="footer-logo" aria-label={strings.site.name}>
        {strings.site.name}
      </a>

      <nav class="footer-nav" aria-label={lang === 'en' ? 'Footer navigation' : 'تنقل التذييل'}>
        <ul>
          {navLinks.map((link) => (
            <li><a href={link.href}>{link.label}</a></li>
          ))}
        </ul>
      </nav>
    </div>

    <div class="footer-divider"></div>

    <div class="footer-bottom">
      <p class="footer-legal">
        &copy; {currentYear} {strings.site.name}. {strings.footer.rights}
      </p>
      <div class="footer-lang">
        <LanguageSwitcher lang={lang} currentPath={getLocalizedPath('/', lang)} />
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--color-warm-gray);
    background-color: var(--color-white);
    margin-top: var(--space-32);
  }

  .footer-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: var(--space-16) var(--content-padding) var(--space-8);
  }

  .footer-top {
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
  }

  .footer-logo {
    font-family: var(--font-display);
    font-weight: 600;
    color: var(--color-charcoal);
    text-decoration: none;
    opacity: 0.7;
  }

  .footer-nav ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .footer-nav a {
    font-size: var(--text-small);
    color: var(--color-charcoal);
    text-decoration: none;
    transition: color 200ms ease;
  }

  .footer-nav a:hover {
    color: var(--color-accent);
  }

  .footer-divider {
    height: 1px;
    background-color: var(--color-warm-gray);
    margin: var(--space-8) 0;
  }

  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-4);
  }

  .footer-legal {
    font-size: var(--text-caption);
    color: var(--color-mid-gray);
  }

  @media (min-width: 48rem) {
    .footer-top {
      flex-direction: row;
      justify-content: space-between;
      align-items: start;
    }

    .footer-nav ul {
      flex-direction: row;
      gap: var(--space-6);
    }
  }
</style>
