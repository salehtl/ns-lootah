---
import type { Lang } from '../i18n/types';
import { t } from '../i18n/translations';
import { getLocalizedPath } from '../i18n/utils';
import LanguageSwitcher from './LanguageSwitcher.astro';
import { Image } from 'astro:assets';
import footerGraphic from '../assets/images/footer-graphic.webp';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const strings = t(lang);
const currentYear = new Date().getFullYear();

const quickLinks = [
  { label: strings.nav.home, href: getLocalizedPath('/', lang) },
  { label: strings.nav.about, href: getLocalizedPath('/about', lang) },
  { label: strings.nav.nslTrading, href: getLocalizedPath('/nsl-trading', lang) },
  { label: strings.nav.projectUpgraded, href: getLocalizedPath('/project-upgraded', lang) },
  { label: strings.nav.news, href: getLocalizedPath('/news', lang) },
  { label: strings.nav.careers, href: getLocalizedPath('/careers', lang) },
];
---

<footer class="footer">
  <div class="footer-inner">
    <div class="footer-top">
      <div class="footer-about">
        <a href={getLocalizedPath('/', lang)} class="footer-logo" aria-label={strings.site.name}>
          <Image src={footerGraphic} alt={strings.alt.logo} width={300} height={66} />
        </a>
        <p class="footer-about-text">{strings.footer.aboutText}</p>
      </div>

      <div class="footer-links">
        <h3 class="footer-heading">{strings.footer.quickLinks}</h3>
        <nav aria-label={lang === 'en' ? 'Footer navigation' : 'تنقل التذييل'}>
          <ul>
            {quickLinks.map((link) => (
              <li><a href={link.href}>{link.label}</a></li>
            ))}
          </ul>
        </nav>
      </div>

      <div class="footer-contact">
        <h3 class="footer-heading">{strings.footer.contactUs}</h3>
        <address class="footer-address">
          <p>{strings.site.address}</p>
          <p><a href={`tel:${strings.site.phone.replace(/\s/g, '')}`}>{strings.site.phone}</a></p>
          <p><a href={`mailto:${strings.site.email}`}>{strings.site.email}</a></p>
        </address>
      </div>
    </div>

    <div class="footer-divider"></div>

    <div class="footer-bottom">
      <p class="footer-legal">
        &copy; {currentYear} {strings.site.name}. {strings.footer.rights}
      </p>
      <div class="footer-lang">
        <LanguageSwitcher lang={lang} currentPath={getLocalizedPath('/', lang)} />
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    background-color: #000000;
    margin-top: var(--space-32);
  }

  .footer-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: var(--space-16) var(--content-padding) var(--space-8);
  }

  .footer-top {
    display: grid;
    gap: var(--space-12);
  }

  .footer-logo {
    display: inline-block;
    text-decoration: none;
  }

  .footer-logo img {
    height: 100px;
    width: auto;
  }

  .footer-about-text {
    color: rgba(255, 255, 255, 0.7);
    font-size: var(--text-small);
    margin-top: var(--space-4);
    line-height: 1.7;
  }

  .footer-heading {
    font-size: var(--text-small);
    font-weight: 600;
    color: var(--color-white);
    margin-bottom: var(--space-4);
  }

  .footer-links ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .footer-links a {
    font-size: var(--text-small);
    color: rgba(255, 255, 255, 0.7);
    text-decoration: none;
    transition: color 0.3s ease;
  }

  .footer-links a:hover {
    color: var(--color-gold);
  }

  .footer-address {
    font-style: normal;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .footer-address p {
    font-size: var(--text-small);
    color: rgba(255, 255, 255, 0.7);
  }

  .footer-address a {
    color: rgba(255, 255, 255, 0.7);
    text-decoration: none;
    transition: color 0.3s ease;
  }

  .footer-address a:hover {
    color: var(--color-gold);
  }

  .footer-divider {
    height: 1px;
    background-color: rgba(255, 255, 255, 0.15);
    margin: var(--space-8) 0;
  }

  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-4);
  }

  .footer-legal {
    font-size: var(--text-caption);
    color: rgba(255, 255, 255, 0.5);
  }

  .footer-lang :global(.lang-switcher) {
    color: rgba(255, 255, 255, 0.7);
  }

  .footer-lang :global(.lang-switcher:hover) {
    color: var(--color-gold);
  }

  @media (min-width: 48rem) {
    .footer-top {
      grid-template-columns: 2fr 1fr 1fr;
    }
  }
</style>
